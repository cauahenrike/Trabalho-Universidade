// Bibliotecas utilizadas
#include <stdio.h>
#include <stdlib.h>
#include <locale.h>
#include <string.h>

// ===============================================
// VARIÁVEL GLOBAL DO CAMINHO BASE (preenchida automaticamente)
// ===============================================
char BASE_DIR[500];

// Detecta automaticamente o caminho da Área de Trabalho
void montarBaseDir()
{
    char *user = getenv("USERPROFILE");  // exemplo: C:\Users\Iury
    if (user == NULL)
    {
        printf("Erro ao detectar o usuário do Windows.\n");
        exit(1);
    }

    // Monta caminho completo da pasta usada pelo Python
    sprintf(BASE_DIR, "%s/Desktop/Sistema_Escola/", user);
}

// Monta o caminho completo do arquivo de notas da disciplina
void montarCaminho(char *destino, const char *disciplina)
{
    sprintf(destino, "%sCadastro de Disciplinas/%s/notas.txt", BASE_DIR, disciplina);
}

// =====================================================
// Função que busca aluno pelo RA
// =====================================================
void buscarAlunoPorRA(char *arquivo)
{
    FILE *arq = fopen(arquivo, "r");
    if (arq == NULL)
    {
        printf("Arquivo não encontrado: '%s'\n", arquivo);
        return;
    }

    char RA_procurado[20];
    printf("Digite o RA do aluno que deseja buscar: ");
    scanf("%19s", RA_procurado);
    while (getchar() != '\n');

    char linha[300];
    char nome[100];
    char RA[20];
    char turma[30];
    float n1, n2, n3, n4;
    int encontrou = 0;

    printf("\n--- Buscando aluno com RA: %s ---\n\n", RA_procurado);

    while (fgets(linha, sizeof(linha), arq))
    {
        int leu = sscanf(
            linha,
            "Aluno: %99[^;]; RA: %19[^;]; Turma: %29[^;]; "
            "Bimestre 1: %f; Bimestre 2: %f; Bimestre 3: %f; Bimestre 4: %f",
            nome, RA, turma, &n1, &n2, &n3, &n4
        );

        if (leu == 7)
        {
            if (strcmp(RA, RA_procurado) == 0)
            {
                printf("ALUNO ENCONTRADO!\n");
                printf("Aluno: %s\n", nome);
                printf("RA: %s\n", RA);
                printf("Turma: %s\n", turma);
                printf("Notas: %.1f, %.1f, %.1f, %.1f\n", n1, n2, n3, n4);

                float media = (n1 + n2 + n3 + n4) / 4;
                printf("Média: %.2f - %s\n", media, media >= 5 ? "APROVADO" : "REPROVADO");

                encontrou = 1;
                break;
            }
        }
    }

    if (!encontrou)
        printf("Nenhum aluno encontrado com RA: %s\n", RA_procurado);

    fclose(arq);
}

// =====================================================
// Função que mostra relatório completo da disciplina
// =====================================================
void mostrarRelatorio(char *arquivo)
{
    FILE *arq = fopen(arquivo, "r");
    if (arq == NULL)
    {
        printf("Arquivo não encontrado: '%s'\n", arquivo);
        return;
    }

    char linha[300];
    char nome[100];
    char RA[20];
    char turma[30];
    float n1, n2, n3, n4;

    printf("\n--- Relatório da Disciplina ---\n\n");

    while (fgets(linha, sizeof(linha), arq))
    {
        int leu = sscanf(
            linha,
            "Aluno: %99[^;]; RA: %19[^;]; Turma: %29[^;]; "
            "Bimestre 1: %f; Bimestre 2: %f; Bimestre 3: %f; Bimestre 4: %f",
            nome, RA, turma, &n1, &n2, &n3, &n4
        );

        if (leu == 7)
        {
            float media = (n1 + n2 + n3 + n4) / 4;

            printf("Aluno: %s | RA: %s | Turma: %s | "
                   "Notas: %.1f, %.1f, %.1f, %.1f | Média: %.2f | %s\n",
                   nome, RA, turma, n1, n2, n3, n4, media,
                   media >= 5 ? "APROVADO" : "REPROVADO");
        }
    }

    fclose(arq);
}

// =====================================================
// Menu principal
// =====================================================
int main()
{
    setlocale(LC_ALL, "Portuguese");

    // Prepara caminho automático da Área de Trabalho
    montarBaseDir();

    int opcao;

    do
    {
        printf("\n===== Sistema Acadêmico - Relatórios =====\n");
        printf("1 - Mostrar todos os alunos (por disciplina)\n");
        printf("2 - Buscar aluno por RA\n");
        printf("0 - Sair\n");
        printf("Escolha uma opção: ");
        scanf("%d", &opcao);
        while (getchar() != '\n');

        switch (opcao)
        {
            case 1:
            case 2:
            {
                int disciplina;
                printf("\nSelecione a disciplina:\n");
                printf("1 - Matematica\n");
                printf("2 - Historia\n");
                printf("3 - Portugues\n");
                printf("4 - Artes\n");
                printf("5 - Geografia\n");
                printf("6 - Fisica\n");
                printf("7 - Algoritmo\n");
                printf("Escolha: ");
                scanf("%d", &disciplina);
                while (getchar() != '\n');

                char caminho[500];

                switch (disciplina)
                {
                    case 1: montarCaminho(caminho, "Matematica"); break;
                    case 2: montarCaminho(caminho, "Historia"); break;
                    case 3: montarCaminho(caminho, "Portugues"); break;
                    case 4: montarCaminho(caminho, "Artes"); break;
                    case 5: montarCaminho(caminho, "Geografia"); break;
                    case 6: montarCaminho(caminho, "Fisica"); break;
                    case 7: montarCaminho(caminho, "Algoritmo"); break;
                    default:
                        printf("Disciplina inválida!\n");
                        continue;
                }

                if (opcao == 1)
                    mostrarRelatorio(caminho);
                else
                    buscarAlunoPorRA(caminho);

                break;
            }

            case 0:
                printf("Saindo do sistema... Até a próxima!\n");
                break;

            default:
                printf("Opção inválida!\n");
        }

    } while (opcao != 0);

    return 0;
}
